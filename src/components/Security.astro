---
import { Image } from "astro:assets";
import privacy from "../assets/screenshots/privacy.png";

const controls = [
	{ title: "Keep knowledge local and in scope", body: "Memory is stored locally by default and separated by user and project, so one workspace does not silently become another's context." },
	{ title: "Grant access explicitly", body: "Tools and connectors begin denied and operate through permissions you approve." },
	{ title: "Inspect what happened", body: "Homun surfaces plans, tool use and connector activity while work is in progress." },
	{ title: "Protect secrets by design", body: "Sensitive credentials belong behind the Vault boundary, not inside readable memory." },
	{ title: "Retain the final say", body: "Correct, export or remove knowledge from active recall when it no longer belongs in the system." },
] as const;
---

<section id="control" class="relative scroll-mt-24 overflow-hidden border-y border-line bg-bg-raised/35 py-24 sm:py-32">
	<div class="glow -left-40 bottom-0 h-96 w-96 opacity-20" aria-hidden="true"></div>
	<div class="section-shell grid items-center gap-14 xl:grid-cols-[1.05fr_.95fr] xl:gap-20">
		<div class="reveal relative">
			<div class="operator-panel p-2.5">
				<div class="flex items-center justify-between px-3 py-2.5">
					<div class="flex items-center gap-2"><span class="status-dot"></span><span class="metric-label">Permission surface</span></div>
					<span class="font-mono text-[9px] uppercase tracking-wider text-faint">User controlled</span>
				</div>
				<div class="device">
					<Image
						src={privacy}
						alt="Homun settings showing local privacy and permission controls"
						widths={[480, 800, 1100]}
						sizes="(max-width: 1024px) 100vw, 560px"
						loading="lazy"
					/>
				</div>
			</div>
		</div>

		<div>
			<p class="eyebrow reveal">Security and control</p>
			<h2 class="reveal mt-4 text-4xl text-cream sm:text-6xl">Useful memory requires ownership.</h2>
			<p class="reveal mt-6 text-lg leading-relaxed text-muted" style="--reveal-delay: 70ms">
				Homun makes the storage, access boundary and activity visible—so persistent context remains something you direct.
			</p>

			<div class="mt-9 grid gap-x-7 gap-y-7 sm:grid-cols-2">
				{controls.map((control, index) => (
					<div class="reveal border-t border-line pt-4" style={`--reveal-delay: ${100 + index * 50}ms`}>
						<div class="mb-3 flex items-center gap-2">
							<span class="font-mono text-[9px] text-accent-bright">0{index + 1}</span>
							<span class="h-px flex-1 bg-line"></span>
						</div>
						<h3 class="text-[15px] text-cream">{control.title}</h3>
						<p class="mt-2 text-sm leading-relaxed text-faint">{control.body}</p>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

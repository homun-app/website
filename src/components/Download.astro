---
const DOWNLOAD = "/guides/download/";
const SELFHOST = "/guides/self-hosting/";

const systems = [
	{
		os: "macOS",
		sub: "Apple silicon & Intel · signed .dmg",
		glyph: `<path d="M16.36 12.9c.02 2.6 2.28 3.46 2.3 3.47-.02.06-.36 1.24-1.19 2.46-.72 1.05-1.47 2.1-2.64 2.12-1.16.02-1.53-.69-2.85-.69-1.32 0-1.73.67-2.83.71-1.13.04-1.99-1.13-2.72-2.18-1.48-2.14-2.61-6.05-1.09-8.69.75-1.31 2.1-2.14 3.56-2.16 1.12-.02 2.17.75 2.85.75.68 0 1.96-.93 3.31-.79.56.02 2.15.23 3.17 1.71-.08.05-1.89 1.1-1.87 3.28M14.13 5.6c.6-.73 1.01-1.74.9-2.75-.87.03-1.92.58-2.55 1.31-.56.64-1.05 1.67-.92 2.66.97.07 1.96-.49 2.57-1.22"/>`,
		fill: true,
	},
	{
		os: "Windows",
		sub: "Windows 10 & 11 · .exe installer",
		glyph: `<path d="M3 5.5 10.5 4.4v7.1H3zM10.5 4.2 21 2.8v8.7H10.5zM3 12.5h7.5v7.1L3 18.5zM10.5 12.5H21v8.7l-10.5-1.4z"/>`,
		fill: true,
	},
	{
		os: "Linux",
		sub: "AppImage · .deb · self-host",
		glyph: `<rect x="3" y="4" width="18" height="16" rx="2.5"/><path d="m7 9 3 3-3 3M13 15h4"/>`,
		fill: false,
	},
] as const;
---

<section id="download" class="relative scroll-mt-24 overflow-hidden py-28 sm:py-36">
	<div class="bg-grid absolute inset-0 -z-10 opacity-70" aria-hidden="true"></div>
	<div class="glow left-1/2 top-1/2 h-[28rem] w-[40rem] -translate-x-1/2 -translate-y-1/2 opacity-40" aria-hidden="true"></div>

	<div class="mx-auto max-w-3xl px-5 text-center">
		<p class="eyebrow reveal">Get Homun</p>
		<h2 class="reveal text-gradient mt-4 text-4xl font-semibold tracking-tight sm:text-6xl">
			Put it to work on your machine.
		</h2>
		<p class="reveal mt-5 text-lg leading-relaxed text-muted" style="--reveal-delay: 80ms">
			A signed desktop build for every platform, or one container you self-host.
			Free to run on your own hardware.
		</p>

		<div class="reveal mt-12 grid gap-4 sm:grid-cols-3" style="--reveal-delay: 140ms">
			{
				systems.map((s) => (
					<a
						href={DOWNLOAD}
						target="_blank"
						rel="noopener"
						class="card card-hover sheen group flex flex-col items-center gap-3 px-5 py-7"
					>
						<span class="flex h-12 w-12 items-center justify-center rounded-xl border border-line bg-bg-raised text-cream transition-colors group-hover:text-accent-bright">
							<svg
								viewBox="0 0 24 24"
								class="h-6 w-6"
								fill={s.fill ? "currentColor" : "none"}
								stroke={s.fill ? "none" : "currentColor"}
								stroke-width="1.6"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
								set:html={s.glyph}
							/>
						</span>
						<span class="text-base font-semibold text-cream">Download for {s.os}</span>
						<span class="text-xs text-faint">{s.sub}</span>
					</a>
				))
			}
		</div>

		<p class="reveal mt-9 text-sm text-faint" style="--reveal-delay: 200ms">
			Prefer the server?
			<a href={SELFHOST} target="_blank" rel="noopener" class="link-accent">Self-host a single container</a>
			· Released under the
			<a href="https://github.com/homun-app" target="_blank" rel="noopener" class="link-accent">FSL-1.1 license</a>.
		</p>
	</div>
</section>

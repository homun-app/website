---
const systems = [
	{ platform: "macos", os: "macOS", detail: "Signed and notarized · Apple silicon" },
	{ platform: "windows", os: "Windows", detail: ".exe installer · available from the public feed" },
	{ platform: "linux", os: "Linux", detail: "Choose AppImage or .deb" },
] as const;
---

<section id="download" class="relative scroll-mt-24 overflow-hidden border-t border-line py-28 sm:py-36">
	<div class="atmosphere absolute inset-0 -z-10" aria-hidden="true"></div>
	<div class="glow left-1/2 top-1/2 h-[30rem] w-[42rem] -translate-x-1/2 -translate-y-1/2 opacity-28" aria-hidden="true"></div>

	<div class="section-shell text-center">
		<p class="eyebrow reveal">Get Homun</p>
		<h2 class="reveal text-gradient mx-auto mt-4 max-w-4xl text-4xl sm:text-6xl">Start without creating an account.</h2>
		<p class="reveal mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted" style="--reveal-delay: 70ms">
			Download the desktop app, connect the models you choose, and keep the core work on your terms.
		</p>

		<div class="reveal mx-auto mt-12 grid max-w-5xl gap-4 sm:grid-cols-3" style="--reveal-delay: 120ms">
			{systems.map((system) => (
				<a href="https://github.com/homun-app/homun-releases/releases/latest" data-download-platform={system.platform} class="operator-panel sheen group p-6 text-left transition-transform duration-300 hover:-translate-y-1">
					<div class="flex items-center justify-between"><span class="metric-label text-accent-bright">Available</span><span class="status-dot"></span></div>
					<h3 class="mt-12 text-2xl text-cream">{system.os}</h3>
					<p class="mt-3 text-sm leading-relaxed text-muted">{system.detail}</p>
					<p data-download-action class="mt-7 text-sm font-semibold text-accent-bright">Download for {system.os} →</p>
				</a>
			))}
		</div>

		<div class="reveal mt-8" style="--reveal-delay: 160ms">
			<button type="button" class="btn btn-ghost" data-download-chooser aria-expanded="false" aria-controls="download-options">
				Download for another platform
			</button>
			<div id="download-options" data-download-options hidden class="mx-auto mt-5 max-w-3xl rounded-2xl border border-line bg-surface/70 p-4 text-left">
				<p data-download-status class="text-sm text-muted" aria-live="polite">Choose an installer.</p>
				<div data-download-list class="mt-3 grid gap-2 sm:grid-cols-2"></div>
			</div>
		</div>

		<p class="reveal mt-9 text-sm text-faint" style="--reveal-delay: 190ms">
			Need help? <a href="/guides/download/" class="link-accent">Read the installation guide</a>.
			Prefer a server setup? <a href="/guides/self-hosting/" class="link-accent">Read the self-hosting guide</a>.
		</p>
	</div>
</section>

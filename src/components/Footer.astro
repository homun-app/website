---
import Wordmark from "./Wordmark.astro";

const columns = [
	{
		heading: "Product",
		links: [
			{ label: "Features", href: "/#features" },
			{ label: "Marketplace", href: "/marketplace" },
			{ label: "Roadmap", href: "/roadmap" },
			{ label: "Changelog", href: "/changelog" },
			{ label: "Download", href: "/#download" },
		],
	},
	{
		heading: "Documentation",
		links: [
			{ label: "Getting started", href: "/guides/getting-started/" },
			{ label: "Core concepts", href: "/concepts/" },
			{ label: "Self-hosting", href: "/guides/self-hosting/" },
			{ label: "Architecture", href: "/reference/architecture/" },
		],
	},
	{
		heading: "More",
		links: [
			{ label: "Memory model", href: "/reference/memory-model/" },
			{ label: "Privacy & security", href: "/guides/security/" },
			{ label: "GitHub", href: "https://github.com/homun-app" },
			{ label: "License (FSL-1.1)", href: "https://github.com/homun-app" },
		],
	},
] as const;

const year = 2026;
---

<footer class="relative border-t border-line">
	<div class="mx-auto max-w-6xl px-5 py-16">
		<div class="grid gap-10 md:grid-cols-[1.4fr_repeat(3,1fr)]">
			<div>
				<Wordmark class="h-6 w-auto text-cream" />
				<p class="mt-4 max-w-xs text-sm leading-relaxed text-faint">
					A personal AI that does the work, on your terms. Local and cloud, your
					data, your permissions.
				</p>
				<div class="mt-5 inline-flex items-center gap-2 rounded-full border border-line bg-surface px-3 py-1.5 text-xs text-muted">
					<span class="h-1.5 w-1.5 rounded-full bg-accent-glow"></span>
					Local and cloud — your call
				</div>
			</div>

			{
				columns.map((col) => (
					<div>
						<h4 class="font-mono text-xs uppercase tracking-wider text-faint">
							{col.heading}
						</h4>
						<ul class="mt-4 space-y-2.5">
							{col.links.map((l) => (
								<li>
									<a
										href={l.href}
										target={l.href.startsWith("http") ? "_blank" : undefined}
										rel={l.href.startsWith("http") ? "noopener" : undefined}
										class="text-sm text-muted transition-colors hover:text-cream"
									>
										{l.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="mt-14 flex flex-col items-center justify-between gap-4 border-t border-line pt-7 sm:flex-row">
			<p class="text-sm text-faint">© {year} Homun. All rights reserved.</p>
			<p class="font-mono text-xs text-faint">your data · your models · your call</p>
		</div>
	</div>
</footer>

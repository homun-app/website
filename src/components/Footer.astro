---
import Wordmark from "./Wordmark.astro";

const columns = [
	{
		heading: "Product",
		links: [
			{ label: "How it works", href: "/#product" },
			{ label: "Models", href: "/#models" },
			{ label: "Local control", href: "/#control" },
			{ label: "Download", href: "/#download" },
		],
	},
	{
		heading: "Ecosystem",
		links: [
			{ label: "Projects", href: "/roadmap" },
			{ label: "Marketplace", href: "/marketplace" },
			{ label: "Changelog", href: "/changelog" },
		],
	},
	{
		heading: "Resources",
		links: [
			{ label: "Documentation", href: "/docs" },
			{ label: "Getting started", href: "/guides/getting-started/" },
			{ label: "Privacy & security", href: "/guides/security/" },
			{ label: "Privacy", href: "/privacy/" },
			{ label: "License", href: "/license/" },
			{ label: "Source code", href: "https://github.com/homun-app/homun-core" },
			{ label: "All releases", href: "https://github.com/homun-app/homun-releases/releases/latest" },
		],
	},
] as const;
---

<footer class="border-t border-line bg-bg-raised/30">
	<div class="section-shell py-16">
		<div class="grid gap-12 md:grid-cols-[1.5fr_repeat(3,1fr)]">
			<div>
				<Wordmark class="h-6 w-auto text-cream" />
				<p class="mt-5 max-w-xs text-sm leading-relaxed text-muted">
					A model-independent AI work environment for projects that continue beyond a single prompt.
				</p>
				<div class="mt-6 inline-flex items-center gap-2 rounded-full border border-line bg-surface px-3 py-1.5 font-mono text-[10px] uppercase tracking-wider text-faint">
					<span class="status-dot"></span> Cloud · source-available · local
				</div>
			</div>

			{columns.map((column) => (
				<div>
					<h3 class="metric-label">{column.heading}</h3>
					<ul class="mt-5 space-y-3">
						{column.links.map((link) => (
							<li><a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noopener" : undefined} data-analytics-download-source={link.label === "All releases" ? "footer" : undefined} class="text-sm text-muted transition-colors hover:text-cream">{link.label}</a></li>
						))}
					</ul>
				</div>
			))}
		</div>

		<div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-line pt-7 sm:flex-row sm:items-center">
			<p class="text-sm text-faint">© 2026 Homun. All rights reserved.</p>
			<p class="font-mono text-[10px] uppercase tracking-[0.15em] text-faint">Your work · your models · your system</p>
		</div>
	</div>
</footer>

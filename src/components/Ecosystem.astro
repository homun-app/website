---
import EcosystemIllustration from "./illustrations/EcosystemIllustration.astro";
import { programsByStage, type RoadmapStage } from "../lib/product-data";

const roadmapMetricDefinitions = [
	{ status: "available", label: "Available" },
	{ status: "building", label: "Building" },
	{ status: "next", label: "Up next" },
] satisfies { status: RoadmapStage; label: string }[];
const roadmapMetrics = roadmapMetricDefinitions.map(({ status, label }) => ({
	status,
	label,
	count: programsByStage(status).length,
}));
---

<section id="ecosystem" class="relative overflow-hidden py-24 sm:py-32">
	<div class="atmosphere absolute inset-0 -z-10" aria-hidden="true"></div>
	<div class="section-shell">
		<div class="grid items-center gap-12 lg:grid-cols-[.82fr_1.18fr] lg:gap-16">
			<div class="max-w-2xl">
				<p class="eyebrow reveal">A living system</p>
				<h2 class="reveal mt-4 text-4xl text-cream sm:text-6xl">Designed to keep growing.</h2>
				<p class="reveal mt-6 max-w-2xl text-lg leading-relaxed text-muted" style="--reveal-delay: 70ms">
					Follow what Homun may become, shape the direction over time, and extend what it can do through a curated ecosystem.
				</p>
			</div>
			<div class="reveal" style="--reveal-delay: 90ms">
				<EcosystemIllustration />
			</div>
		</div>

		<div class="mt-14 grid gap-5 lg:grid-cols-[1.12fr_.88fr]">
			<article class="operator-panel sheen reveal flex min-h-[25rem] flex-col justify-between p-7 sm:p-9">
				<div class="flex items-center justify-between">
					<span class="eyebrow">Projects</span>
					<span class="rounded-full border border-line px-2.5 py-1 font-mono text-[9px] uppercase tracking-wider text-faint">Public roadmap</span>
				</div>
				<div class="my-12 grid grid-cols-3 gap-2">
					{roadmapMetrics.map(({ status, label, count }) => (
						<div
							data-status={status}
							data-count={count}
							class={`rounded-lg border p-3 ${status === "building" ? "border-accent/25 bg-accent/5" : "border-line bg-bg/45"}`}
						>
							<p class={`metric-label ${status === "building" ? "text-accent-bright" : ""}`}>{label}</p>
							<p class="mt-4 text-2xl text-cream">{String(count).padStart(2, "0")}</p>
						</div>
					))}
				</div>
				<div>
					<h3 class="text-3xl text-cream">See the direction.<br />Help shape what comes next.</h3>
					<p class="mt-4 max-w-xl text-sm leading-relaxed text-muted">
						See what Homun already provides, the team-process product being built and the decided extensions that come next. Submit workflow ideas through GitHub now. Voting stays advisory and never creates a delivery commitment. Browsing the roadmap does not require a Homun account. Proposing ideas and voting require a GitHub account.
					</p>
					<div class="mt-7 flex flex-wrap items-center gap-4">
						<a href="/roadmap" class="btn btn-ghost">Browse Projects</a>
					<span class="font-mono text-[10px] uppercase tracking-wider text-faint">GitHub workflow proposals · Available now</span>
					</div>
				</div>
			</article>

			<article class="card reveal flex min-h-[25rem] flex-col justify-between p-7 sm:p-9" style="--reveal-delay: 80ms">
				<div class="flex items-center justify-between">
					<span class="eyebrow">Workflow packs</span>
					<span class="rounded-full border border-accent/30 bg-accent/8 px-2.5 py-1 font-mono text-[9px] uppercase tracking-wider text-accent-bright">Official first</span>
				</div>
				<div class="my-10 space-y-2.5" aria-hidden="true">
					<div class="flex items-center justify-between rounded-lg border border-line bg-bg/45 px-4 py-3"><span class="text-sm text-cream">Client Work</span><span class="metric-label">Evaluating</span></div>
					<div class="flex items-center justify-between rounded-lg border border-line bg-bg/45 px-4 py-3"><span class="text-sm text-cream">Sales Operations</span><span class="metric-label">Evaluating</span></div>
					<div class="flex items-center justify-between rounded-lg border border-dashed border-line px-4 py-3"><span class="text-sm text-faint">Internal Operations</span><span class="metric-label">Evaluating</span></div>
				</div>
				<div>
					<h3 class="text-3xl text-cream">Official Homun workflow packs.</h3>
					<p class="mt-4 text-sm leading-relaxed text-muted">
						Developed and maintained by Homun, each pack combines a process, connected tools, permissions, templates and review rules. The developer platform follows after official packs prove the product contract.
					</p>
					<div class="mt-7 flex flex-wrap items-center gap-4">
						<a href="/roadmap/#workflow-ideas-title" class="btn btn-ghost">Explore workflow ideas</a>
						<span class="font-mono text-[10px] uppercase tracking-wider text-faint">Official pilots · Before developer access</span>
					</div>
				</div>
			</article>
		</div>
	</div>
</section>

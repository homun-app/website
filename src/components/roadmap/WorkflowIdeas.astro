---
import type { RoadmapItem } from "../../lib/product-data";
import RoadmapParticipation from "./RoadmapParticipation.astro";

interface Props { items: RoadmapItem[] }
const { items } = Astro.props;
const evaluationLabel = {
	evaluating: "Evaluating",
	selected_for_pilot: "Selected for pilot",
	removed: "Removed",
};
---

<section aria-labelledby="workflow-ideas-title">
	<div class="grid gap-6 lg:grid-cols-[1fr_.7fr] lg:items-end">
		<div>
			<p class="eyebrow">Official workflow ideas</p>
			<h2 id="workflow-ideas-title" class="mt-3 text-3xl font-semibold sm:text-4xl">Business workflows we are evaluating</h2>
		</div>
		<p class="text-sm leading-relaxed text-muted">
			Homun's first workflow packs will be developed and maintained by us. Each pack combines process design, connected tools, permissions, templates, review rules and measurable outcomes.
		</p>
	</div>
	<div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
		{items.map((item) => (
			<article class="project-card card card-hover relative flex flex-col p-5" data-roadmap-area={item.area}>
				<div class="flex items-start justify-between gap-3">
					<span class="font-mono text-[10px] uppercase tracking-[.12em] text-accent-bright">{item.area}</span>
					<span class="pill text-[10px]">{evaluationLabel[item.evaluationState ?? "evaluating"]}</span>
				</div>
				<h3 class="mt-4 text-xl font-semibold">
					<a href={`/roadmap/${item.slug}/`} class="project-detail-link focus-visible:outline-none">{item.title}</a>
				</h3>
				<p class="mt-3 text-sm leading-relaxed text-muted">{item.outcome}</p>
				<div class="mt-auto pt-2"><RoadmapParticipation item={item} variant="card" /></div>
			</article>
		))}
		<article class="rounded-2xl border border-dashed border-line-strong p-5">
			<p class="eyebrow">Help shape Homun</p>
			<h3 class="mt-4 text-xl font-semibold">A workflow we should evaluate?</h3>
			<p class="mt-3 text-sm leading-relaxed text-muted">Describe the team, the recurring process and the outcome that matters.</p>
			<a href="https://github.com/homun-app/homun/issues/new?template=roadmap-idea.yml" target="_blank" rel="noopener" class="btn mt-5 w-full border border-line-strong text-xs text-cream hover:border-accent/50">Suggest an idea</a>
		</article>
	</div>
</section>

<style>
	.project-detail-link::after { content: ""; position: absolute; inset: 0; }
	.project-detail-link:focus-visible::after { border-radius: inherit; outline: 2px solid var(--color-accent); outline-offset: 2px; }
	.project-card :global([data-roadmap-participation]) { position: relative; z-index: 10; }
</style>

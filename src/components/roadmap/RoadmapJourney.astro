---
import type { RoadmapItem } from "../../lib/product-data";
import ProgramMilestones from "./ProgramMilestones.astro";
import RoadmapParticipation from "./RoadmapParticipation.astro";

interface Props {
	items: RoadmapItem[];
	eyebrow: string;
	title: string;
	hint: string;
	filterable?: boolean;
}
const { items, eyebrow, title, hint, filterable = false } = Astro.props;
const areas = [...new Set(items.map((item) => item.area))].sort();
---

<section aria-labelledby={`roadmap-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}>
	<div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
		<div>
			<p class="eyebrow">{eyebrow}</p>
			<h2 id={`roadmap-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`} class="mt-3 text-3xl font-semibold sm:text-4xl">{title}</h2>
			<p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted">{hint}</p>
		</div>
		{filterable && areas.length > 1 && (
			<div class="flex flex-wrap gap-2" aria-label={`Filter ${title} by area`}>
				<button class="roadmap-filter pill border-accent/40 text-accent-bright" type="button" data-roadmap-filter="all" aria-pressed="true">All</button>
				{areas.map((area) => <button class="roadmap-filter pill" type="button" data-roadmap-filter={area} aria-pressed="false">{area}</button>)}
			</div>
		)}
	</div>
	<div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3" data-roadmap-grid>
		{items.map((item) => (
			<article class="project-card card card-hover relative flex flex-col p-5" data-roadmap-area={item.area}>
				<span class="font-mono text-[10px] uppercase tracking-[.12em] text-accent-bright">{item.area}</span>
				<h3 class="mt-3 text-xl font-semibold">
					<a href={`/roadmap/${item.slug}/`} class="project-detail-link focus-visible:outline-none">{item.title}</a>
				</h3>
				<p class="mt-3 text-sm leading-relaxed text-muted">{item.outcome}</p>
				{item.milestones.length > 0 && <ProgramMilestones milestones={item.milestones.slice(0, 3)} compact />}
				<div class="mt-auto pt-2"><RoadmapParticipation item={item} variant="card" /></div>
			</article>
		))}
	</div>
</section>

<script>
	for (const grid of document.querySelectorAll<HTMLElement>("[data-roadmap-grid]")) {
		const section = grid.closest("section");
		const filters = section?.querySelectorAll<HTMLButtonElement>("[data-roadmap-filter]") ?? [];
		const cards = grid.querySelectorAll<HTMLElement>("[data-roadmap-area]");
		for (const filter of filters) {
			filter.addEventListener("click", () => {
				const selected = filter.dataset.roadmapFilter;
				for (const button of filters) button.setAttribute("aria-pressed", String(button === filter));
				for (const card of cards) card.hidden = selected !== "all" && card.dataset.roadmapArea !== selected;
			});
		}
	}
</script>

<style>
	.project-card[hidden] { display: none; }
	.project-detail-link::after { content: ""; position: absolute; inset: 0; }
	.project-detail-link:focus-visible::after { border-radius: inherit; outline: 2px solid var(--color-accent); outline-offset: 2px; }
	.project-card :global([data-roadmap-participation]) { position: relative; z-index: 10; }
</style>

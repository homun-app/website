---
import type { RoadmapItem } from "../../lib/product-data";
import RoadmapOrbitIllustration from "../illustrations/RoadmapOrbitIllustration.astro";
import ProgramMilestones from "./ProgramMilestones.astro";

interface Props { project: RoadmapItem }
const { project } = Astro.props;
if (project.itemType !== "strategic_program" || project.stage !== "building") {
	throw new Error(`Featured roadmap project must be a Building strategic program: ${project.slug}`);
}
const updated = project.publicUpdateDate
	? new Date(`${project.publicUpdateDate}T00:00:00Z`).toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
		timeZone: "UTC",
	})
	: null;
---

<article class="featured card sheen relative min-h-[29rem] overflow-hidden p-6 sm:p-8">
	<div class="relative z-10 max-w-[31rem]">
		<div class="flex flex-wrap items-center gap-3">
			<p class="eyebrow">Building now</p>
			{updated && <span class="pill text-[10px]" data-public-update-date={project.publicUpdateDate}>Updated {updated}</span>}
		</div>
		<p class="mt-6 font-mono text-[11px] uppercase tracking-[.14em] text-faint">{project.area}</p>
		<h2 class="mt-2 text-3xl font-semibold sm:text-4xl">{project.title}</h2>
		<p class="mt-4 text-[15px] leading-relaxed text-muted">{project.outcome}</p>
		<ProgramMilestones milestones={project.milestones.slice(0, 3)} compact />
		<a href={`/roadmap/${project.slug}/`} class="link-accent mt-7 inline-flex items-center gap-2 text-sm font-semibold">
			See the milestones <span aria-hidden="true">→</span>
		</a>
	</div>
	<div class="art absolute -bottom-12 -right-12 w-[23rem] opacity-45 sm:right-0 sm:w-[28rem] lg:opacity-70">
		<RoadmapOrbitIllustration />
	</div>
</article>

<style>
	.featured { background: radial-gradient(circle at 83% 52%, rgba(53, 171, 145, .15), transparent 38%), linear-gradient(145deg, rgba(13, 36, 31, .95), rgba(6, 13, 11, .96)); }
	@media (max-width: 639px) { .featured { padding-bottom: 12rem; } .art { opacity: .42; } }
</style>

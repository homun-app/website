---
const stages = [
	{ label: "Remember", text: "Keep projects, decisions and working context continuous." },
	{ label: "Coordinate", text: "Turn recurring work into visible, reviewable processes." },
	{ label: "Connect", text: "Bring people, channels and tools into the same governed flow." },
	{ label: "Adapt", text: "Improve knowledge and behavior from measured company work." },
];
---

<section aria-labelledby="product-journey-title">
	<p class="eyebrow">From useful work to company intelligence</p>
	<h2 id="product-journey-title" class="mt-3 text-3xl font-semibold sm:text-4xl">One continuous product journey</h2>
	<div class="relative mt-8 grid gap-3 md:grid-cols-4">
		<div class="absolute left-[8%] right-[8%] top-6 hidden h-px bg-gradient-to-r from-accent via-[#6c8fee] to-[#cb70c2] opacity-40 md:block" aria-hidden="true"></div>
		{stages.map((stage, index) => (
			<article class="card relative p-5">
				<div class="relative z-10 flex h-7 w-7 items-center justify-center rounded-full border border-accent/35 bg-bg font-mono text-[10px] text-accent-bright">{index + 1}</div>
				<h3 class="mt-5 text-xl font-semibold">{stage.label}</h3>
				<p class="mt-3 text-sm leading-relaxed text-muted">{stage.text}</p>
			</article>
		))}
	</div>
</section>

---
interface Props { compact?: boolean }
const { compact = false } = Astro.props;
---

<div class:list={["border border-dashed border-line-strong", compact ? "rounded-xl p-4" : "card p-6 sm:p-7"]} aria-label="Suggest a roadmap idea">
	<p class="font-mono text-[10px] uppercase tracking-[.12em] text-accent-bright">Help shape Homun</p>
	<p class="mt-2 text-xs leading-relaxed text-faint">Propose a direction for the community to discuss and evaluate.</p>
	<a href="https://github.com/homun-app/homun/issues/new?template=roadmap-idea.yml" target="_blank" rel="noopener" class="btn mt-4 w-full border border-line-strong text-xs text-cream hover:border-accent/50">Suggest an idea</a>
</div>

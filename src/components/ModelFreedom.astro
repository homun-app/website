---
const choices = [
	{ label: "Cloud", detail: "Use compatible hosted providers when reach and speed matter.", code: "REMOTE" },
	{ label: "Open source", detail: "Choose models whose weights and ecosystem stay accessible.", code: "OPEN" },
	{ label: "Local", detail: "Run models on your own hardware when the task and machine allow it.", code: "LOCAL" },
] as const;
---

<section id="models" class="scroll-mt-24 border-y border-line bg-bg-raised/35 py-24 sm:py-32">
	<div class="section-shell">
		<div class="mx-auto max-w-3xl text-center">
			<p class="eyebrow reveal">Model freedom</p>
			<h2 class="reveal mt-4 text-4xl text-cream sm:text-6xl">Cloud, open source, or local.</h2>
			<p class="reveal mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted" style="--reveal-delay: 70ms">
				The model is an engine. Your projects, memory, tools and permissions remain the system.
			</p>
		</div>

		<div class="relative mx-auto mt-14 max-w-5xl">
			<div class="pointer-events-none absolute left-1/2 top-1/2 hidden h-px w-[82%] -translate-x-1/2 bg-gradient-to-r from-accent/30 via-accent/10 to-transparent lg:block" aria-hidden="true"></div>
			<div class="grid items-stretch gap-4 sm:grid-cols-3 lg:grid-cols-[1.35fr_repeat(3,1fr)]">
				<div class="operator-panel sheen reveal flex min-h-64 flex-col justify-between p-7 sm:col-span-3 lg:col-span-1" style="--reveal-delay: 60ms">
					<div class="flex items-center justify-between">
						<span class="metric-label text-accent-bright">Persistent layer</span>
						<span class="status-dot signal-pulse"></span>
					</div>
					<div>
						<p class="font-mono text-[11px] uppercase tracking-[0.16em] text-faint">Homun workspace</p>
						<h3 class="mt-3 text-3xl text-cream">One system.<br />Replaceable engines.</h3>
					</div>
					<div class="grid grid-cols-2 gap-x-4 gap-y-2 border-t border-line pt-5 font-mono text-[10px] uppercase tracking-wider text-muted">
						<span>Projects</span><span>Memory</span><span>Tools</span><span>Permissions</span>
					</div>
				</div>

				{choices.map((choice, index) => (
					<article class="reveal card p-6" style={`--reveal-delay: ${110 + index * 60}ms`}>
						<div class="flex items-center justify-between">
							<span class="metric-label">{choice.code}</span>
							<span class="h-2 w-2 rounded-full border border-accent/50"></span>
						</div>
						<h3 class="mt-10 text-xl text-cream">{choice.label}</h3>
						<p class="mt-3 text-sm leading-relaxed text-muted">{choice.detail}</p>
					</article>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.connected-workspace {
		position: relative;
		overflow: hidden;
		border: 1px solid var(--color-line-strong);
		border-radius: 1.35rem;
		background:
			radial-gradient(circle at 54% 49%, rgba(80, 223, 197, 0.13), transparent 48%),
			linear-gradient(155deg, rgba(10, 22, 18, 0.94), rgba(5, 9, 8, 0.98));
		box-shadow: var(--shadow-lift);
	}

	.scene-label {
		position: absolute;
		inset: 0.95rem 1.05rem auto;
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 0.56rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-faint);
	}

	svg { display: block; width: 100%; height: auto; }
	.scene-object { animation: workshop-drift 13s ease-in-out infinite alternate; transform-box: fill-box; transform-origin: center; }
	.telegram-token { animation-delay: -3s; }
	.composio-tool { animation-delay: -6s; }
	.mcp-tool { animation-delay: -9s; }
	.reply-output { animation-delay: -4.5s; }
	.runway-signal { stroke-dasharray: 12 14; animation: runway-signal 9s linear infinite; }
	.runway-light { animation: workshop-light 4.5s ease-in-out infinite; }
	.light-two { animation-delay: -2.25s; }

	@keyframes workshop-drift { to { transform: translateY(-4px); } }
	@keyframes runway-signal { to { stroke-dashoffset: -104; } }
	@keyframes workshop-light { 0%, 100% { opacity: .32; } 50% { opacity: 1; filter: drop-shadow(0 0 9px #55dfc0); } }

	@media (max-width: 640px) {
		.scene-label { font-size: 0.48rem; }
		.connected-workspace svg { width: 112%; margin-left: -6%; }
	}

	@media (prefers-reduced-motion: reduce) {
		.scene-object,
		.runway-signal,
		.runway-light { animation: none; }
	}
</style>

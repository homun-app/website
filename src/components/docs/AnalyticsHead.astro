---
import Head from "@astrojs/starlight/components/Head.astro";

const isGenerated404 = Astro.url.pathname === "/404/";
---

<Head />
{
	!isGenerated404 && (
		<>
			<script
				is:inline
				defer
				src="https://cloud.umami.is/script.js"
				data-website-id="f3bdb523-4352-430b-b2a2-c7fdf4c0131f"
				data-do-not-track="true"
				data-exclude-search="true"
				data-exclude-hash="true"
				data-domains="homun.app,www.homun.app"
			></script>
			<script>
				import { initAnalyticsTracking } from "../../scripts/analytics.mjs";
				initAnalyticsTracking();
			</script>
		</>
	)
}

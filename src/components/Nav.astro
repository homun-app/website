---
import Wordmark from "./Wordmark.astro";

const links = [
	{ label: "Product", href: "/#product" },
	{ label: "Models", href: "/#models" },
	{ label: "Projects", href: "/roadmap" },
	{ label: "Marketplace", href: "/marketplace" },
	{ label: "Docs", href: "/docs" },
] as const;
---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-300">
	<nav class="section-shell flex items-center justify-between gap-4 py-3.5" aria-label="Primary navigation">
		<a href="/" class="flex items-center" aria-label="Homun — home">
			<Wordmark class="h-[1.3rem] w-auto text-cream" />
		</a>

		<div class="hidden items-center gap-1 md:flex">
			{links.map((link) => (
				<a href={link.href} class="rounded-lg px-3 py-2 text-sm text-muted transition-colors hover:text-cream">
					{link.label}
				</a>
			))}
		</div>

		<div class="flex items-center gap-2">
			<span class="hidden items-center gap-1.5 px-2 text-sm text-faint lg:flex" aria-disabled="true">
				Sign in <span class="rounded-full border border-line px-1.5 py-0.5 font-mono text-[9px] uppercase tracking-wider">Soon</span>
			</span>
			<a href="/#download" class="btn btn-primary min-h-9 px-4 py-2 text-sm">Download</a>
			<button
				id="nav-toggle"
				class="flex h-10 w-10 items-center justify-center rounded-lg text-cream md:hidden"
				aria-label="Open menu"
				aria-expanded="false"
				aria-controls="nav-mobile"
			>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
					<path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"></path>
				</svg>
			</button>
		</div>
	</nav>

	<div id="nav-mobile" class="hidden border-t border-line bg-bg/95 px-4 py-4 backdrop-blur-xl md:hidden">
		<div class="mx-auto flex max-w-6xl flex-col gap-1">
			{links.map((link) => (
				<a href={link.href} class="rounded-lg px-3 py-3 text-[15px] text-muted hover:bg-surface hover:text-cream">
					{link.label}
				</a>
			))}
			<div class="mt-2 flex items-center gap-2 border-t border-line px-3 pt-4 text-sm text-faint">
				Sign in <span class="rounded-full border border-line px-1.5 py-0.5 font-mono text-[9px] uppercase tracking-wider">Soon</span>
			</div>
		</div>
	</div>
</header>

<script is:inline>
	(() => {
		const nav = document.getElementById("site-nav");
		const toggle = document.getElementById("nav-toggle");
		const sheet = document.getElementById("nav-mobile");
		if (!nav || !toggle || !sheet) return;

		const onScroll = () => nav.classList.toggle("nav-scrolled", window.scrollY > 12);
		onScroll();
		window.addEventListener("scroll", onScroll, { passive: true });

		toggle.addEventListener("click", () => {
			const open = sheet.classList.toggle("hidden") === false;
			toggle.setAttribute("aria-expanded", String(open));
			toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
		});
		sheet.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => {
			sheet.classList.add("hidden");
			toggle.setAttribute("aria-expanded", "false");
			toggle.setAttribute("aria-label", "Open menu");
		}));
	})();
</script>

<style>
	#site-nav.nav-scrolled {
		border-bottom-color: var(--color-line);
		background: color-mix(in srgb, var(--color-bg) 78%, transparent);
		backdrop-filter: blur(16px) saturate(1.35);
		-webkit-backdrop-filter: blur(16px) saturate(1.35);
	}
</style>

---
import Wordmark from "./Wordmark.astro";

const links = [
	{ label: "Features", href: "/#features" },
	{ label: "Marketplace", href: "/marketplace" },
	{ label: "Roadmap", href: "/roadmap" },
	{ label: "Changelog", href: "/changelog" },
	{ label: "Docs", href: "/docs" },
];
---

<header
	id="site-nav"
	class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-300"
>
	<nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3.5">
		<a href="/" class="flex items-center" aria-label="Homun — home">
			<Wordmark class="h-[1.35rem] w-auto text-cream" />
		</a>

		<div class="hidden items-center gap-1 md:flex">
			{
				links.map((l) => (
					<a
						href={l.href}
						target={l.external ? "_blank" : undefined}
						rel={l.external ? "noopener" : undefined}
						class="rounded-lg px-3 py-2 text-sm text-muted transition-colors hover:text-cream"
					>
						{l.label}
					</a>
				))
			}
		</div>

		<div class="flex items-center gap-2">
			<a
				href="https://github.com/homun-app"
				target="_blank"
				rel="noopener"
				aria-label="Homun on GitHub"
				class="hidden h-9 w-9 items-center justify-center rounded-lg text-muted transition-colors hover:bg-surface hover:text-cream sm:flex"
			>
				<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
					<path
						d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02.8-.22 1.65-.33 2.5-.33.85 0 1.7.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85 0 1.34-.01 2.42-.01 2.75 0 .27.18.58.69.48A10.01 10.01 0 0 0 22 12c0-5.52-4.48-10-10-10z"
					></path>
				</svg>
			</a>
			<a href="#download" class="btn btn-primary px-4 py-2 text-sm">Download</a>

			<button
				id="nav-toggle"
				class="flex h-9 w-9 items-center justify-center rounded-lg text-cream md:hidden"
				aria-label="Open menu"
				aria-expanded="false"
			>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
					<path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"></path>
				</svg>
			</button>
		</div>
	</nav>

	<!-- Mobile sheet -->
	<div
		id="nav-mobile"
		class="hidden border-t border-line bg-bg/95 px-5 py-4 backdrop-blur-xl md:hidden"
	>
		<div class="flex flex-col gap-1">
			{
				links.map((l) => (
					<a
						href={l.href}
						target={l.external ? "_blank" : undefined}
						rel={l.external ? "noopener" : undefined}
						class="rounded-lg px-3 py-2.5 text-[15px] text-muted hover:bg-surface hover:text-cream"
					>
						{l.label}
					</a>
				))
			}
		</div>
	</div>
</header>

<script is:inline>
	(() => {
		const nav = document.getElementById("site-nav");
		const onScroll = () => {
			if (window.scrollY > 12) nav.classList.add("nav-scrolled");
			else nav.classList.remove("nav-scrolled");
		};
		onScroll();
		window.addEventListener("scroll", onScroll, { passive: true });

		const toggle = document.getElementById("nav-toggle");
		const sheet = document.getElementById("nav-mobile");
		toggle.addEventListener("click", () => {
			const open = sheet.classList.toggle("hidden") === false;
			toggle.setAttribute("aria-expanded", String(open));
		});
		sheet.querySelectorAll("a").forEach((a) =>
			a.addEventListener("click", () => sheet.classList.add("hidden")),
		);
	})();
</script>

<style>
	#site-nav.nav-scrolled {
		background-color: color-mix(in srgb, var(--color-bg) 72%, transparent);
		border-bottom-color: var(--color-line);
		backdrop-filter: blur(14px) saturate(1.4);
		-webkit-backdrop-filter: blur(14px) saturate(1.4);
	}
</style>

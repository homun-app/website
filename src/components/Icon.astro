---
// Lightweight inline icon set (stroke style, 24×24). Brand/OS glyphs that need
// fills live where they're used; these are the feature/utility marks.
interface Props {
	name: keyof typeof icons;
	class?: string;
}

const icons = {
	// memory: a small knowledge graph
	graph:
		'<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="m8.6 13.5 6.8 4M15.4 6.5l-6.8 4"/>',
	// the local computer
	monitor: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>',
	// channels
	send: '<path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4z"/>',
	// automations
	zap: '<path d="M13 2 3 14h7l-1 8 10-12h-7z"/>',
	// models / router
	cpu: '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2"/>',
	// chat
	chat: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>',
	// skills
	layers:
		'<path d="m12 2 9 5-9 5-9-5 9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 17 9 5 9-5"/>',
	// connectors
	plug: '<path d="M12 22v-5M9 8V2M15 8V2M18 8v3a6 6 0 0 1-12 0V8Z"/>',
	// proactivity
	sparkles:
		'<path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9Z"/><path d="M19 13l.8 2.2L22 16l-2.2.8L19 19l-.8-2.2L16 16l2.2-.8Z"/>',
	// local-first storage
	database:
		'<ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v14c0 1.66 3.58 3 8 3s8-1.34 8-3V5"/><path d="M4 12c0 1.66 3.58 3 8 3s8-1.34 8-3"/>',
	// privacy
	shield:
		'<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1Z"/>',
	lock: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
	eye: '<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>',
	check: '<path d="M20 6 9 17l-5-5"/>',
	arrowRight: '<path d="M5 12h14M13 6l6 6-6 6"/>',
	arrowUpRight: '<path d="M7 7h10v10M7 17 17 7"/>',
	// observe / apprentice loop
	observe: '<circle cx="12" cy="12" r="3"/><path d="M12 5v2M12 17v2M5 12h2M17 12h2"/>',
	// presentations add-on
	presentation:
		'<rect x="3" y="4" width="18" height="12" rx="1.5"/><path d="M12 16v4M8.5 20h7M7.5 11l2.5-2.5 2 2 3.5-3.5"/>',
	// marketplace
	grid: '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
	download:
		'<path d="M12 3v12M7 10l5 5 5-5M5 21h14"/>',
} as const;

const { name, class: cls = "h-5 w-5" } = Astro.props;
---

<svg
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.6"
	stroke-linecap="round"
	stroke-linejoin="round"
	class={cls}
	aria-hidden="true"
	set:html={icons[name]}
/>

---
import Page from "../layouts/Page.astro";
import { getCollection } from "astro:content";

const items = await getCollection("roadmap");

const columns = [
	{ key: "exploring", label: "Exploring", hint: "Researching the idea", dot: "bg-faint" },
	{ key: "planned", label: "Planned", hint: "Committed, not started", dot: "bg-muted" },
	{ key: "in-progress", label: "In progress", hint: "Being built now", dot: "bg-accent-bright" },
	{ key: "shipped", label: "Shipped", hint: "Live in the app", dot: "bg-accent" },
] as const;

const inColumn = (key: string) =>
	items
		.filter((i) => i.data.status === key)
		.sort((a, b) => a.data.order - b.data.order);
---

<Page
	title="Roadmap — Homun"
	description="Where Homun is going — what we're exploring, building, and have already shipped."
>
	<section class="relative overflow-hidden pt-36 pb-10 sm:pt-44">
		<div class="bg-grid absolute inset-0 -z-10" aria-hidden="true"></div>
		<div class="glow left-1/2 top-0 h-80 w-[40rem] -translate-x-1/2 opacity-30" aria-hidden="true"></div>
		<div class="mx-auto max-w-6xl px-5">
			<p class="eyebrow reveal">Roadmap</p>
			<h1 class="reveal text-gradient mt-4 text-5xl font-semibold sm:text-6xl">
				Where Homun is going.
			</h1>
			<p class="reveal mt-5 max-w-2xl text-lg leading-relaxed text-muted">
				A living, high-level view of what we're exploring, building, and have
				already shipped. Curated, and always moving.
			</p>
		</div>
	</section>

	<section class="pb-28">
		<div class="mx-auto max-w-6xl px-5">
			<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
				{
					columns.map((col) => (
						<div class="reveal">
							<div class="mb-1 flex items-center gap-2.5 border-b border-line pb-3">
								<span class={`h-2 w-2 rounded-full ${col.dot}`} />
								<h2 class="text-sm font-semibold text-cream">{col.label}</h2>
								<span class="ml-auto font-mono text-xs text-faint">
									{inColumn(col.key).length}
								</span>
							</div>
							<p class="mb-4 mt-2 text-xs text-faint">{col.hint}</p>
							<div class="space-y-3">
								{inColumn(col.key).map((item) => (
									<article class="card card-hover sheen p-4">
										{item.data.area && (
											<span class="font-mono text-[10px] uppercase tracking-wider text-accent-bright">
												{item.data.area}
											</span>
										)}
										<h3 class="mt-1 text-[15px] font-semibold leading-snug text-cream">
											{item.data.title}
										</h3>
										<p class="mt-1.5 text-[13px] leading-relaxed text-faint">
											{item.data.description}
										</p>
									</article>
								))}
							</div>
						</div>
					))
				}
			</div>

			<p class="mt-14 text-center text-sm text-faint">
				Want something on here?
				<a href="https://github.com/homun-app" target="_blank" rel="noopener" class="link-accent">
					Open an issue on GitHub
				</a>.
			</p>
		</div>
	</section>
</Page>

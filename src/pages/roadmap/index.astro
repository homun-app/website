---
import Page from "../../layouts/Page.astro";
import LatestRelease from "../../components/roadmap/LatestRelease.astro";
import ReleaseHistory from "../../components/roadmap/ReleaseHistory.astro";
import RoadmapJourney from "../../components/roadmap/RoadmapJourney.astro";
import RoadmapNow from "../../components/roadmap/RoadmapNow.astro";
import RoadmapVisionHero from "../../components/roadmap/RoadmapVisionHero.astro";
import WorkflowIdeas from "../../components/roadmap/WorkflowIdeas.astro";
import {
	latestRelease,
	programsByStage,
	projectBySlug,
	releases,
	roadmapSyncedAt,
	workflowIdeas,
} from "../../lib/product-data";

const synced = new Date(roadmapSyncedAt).toLocaleDateString("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
});
const upNext = programsByStage("next");
const exploring = programsByStage("exploring");
const adaptive = exploring.filter(({ slug }) => slug === "adaptive-company-intelligence");
const otherExploring = exploring.filter(({ slug }) => slug !== "adaptive-company-intelligence");
const operational = projectBySlug("operational-workspace");
const flow = projectBySlug("homun-flow");
if (!operational || !flow) throw new Error("Roadmap current-product programs are missing");
---

<Page title="Roadmap — Homun" description="How Homun is becoming an operational process system for small teams.">
	<RoadmapVisionHero synced={synced} />
	<section class="pb-20 pt-4">
		<div class="mx-auto max-w-6xl px-5"><RoadmapNow operational={operational} flow={flow} /></div>
	</section>

	<section class="pb-20">
		<div class="mx-auto max-w-6xl px-5">
			<RoadmapJourney
				items={upNext}
				eyebrow="Decided product direction"
				title="Up next"
				hint="Team identity, mobile continuity and more communication channels extend Homun Flow into daily company work."
				filterable
			/>
		</div>
	</section>

	<section class="pb-20">
		<div class="mx-auto max-w-6xl px-5"><WorkflowIdeas items={workflowIdeas} /></div>
	</section>

	<section class="pb-20">
		<div class="mx-auto max-w-6xl px-5">
			<RoadmapJourney
				items={adaptive}
				eyebrow="Long-term product advantage"
				title="Adaptive Company Intelligence"
				hint="A measured progression from company profile and knowledge to process learning, evaluation and specialized small models."
			/>
		</div>
	</section>

	<section class="pb-20">
		<div class="mx-auto max-w-6xl px-5">
			<RoadmapJourney
				items={otherExploring}
				eyebrow="Research, not commitments"
				title="Exploring"
				hint="Directions we are evaluating after the core team-process product becomes demonstrably useful."
			/>
		</div>
	</section>

	<section class="pb-28">
		<div class="mx-auto grid max-w-6xl gap-5 px-5 lg:grid-cols-[1.2fr_.8fr]">
			{releases.length > 0 && <ReleaseHistory releases={releases.slice(0, 4)} />}
			{latestRelease && <LatestRelease release={latestRelease} />}
		</div>
	</section>
</Page>

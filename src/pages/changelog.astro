---
import Page from "../layouts/Page.astro";
import { getCollection, render } from "astro:content";

const entries = (await getCollection("changelog")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const items = await Promise.all(
	entries.map(async (entry) => ({ entry, Content: (await render(entry)).Content })),
);

const fmt = (d: Date) =>
	d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<Page title="Changelog — Homun" description="What's new in Homun — releases, features and fixes.">
	<section class="relative overflow-hidden pt-36 pb-10 sm:pt-44">
		<div class="glow left-1/2 top-0 h-72 w-[36rem] -translate-x-1/2 opacity-25" aria-hidden="true"></div>
		<div class="mx-auto max-w-3xl px-5">
			<div class="flex items-center justify-between gap-4">
				<p class="eyebrow reveal">Changelog</p>
				<a href="/changelog/rss.xml" class="pill reveal text-xs hover:border-line-strong">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5">
						<path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16" stroke-linecap="round"></path>
						<circle cx="5" cy="19" r="1.5" fill="currentColor" stroke="none"></circle>
					</svg>
					RSS
				</a>
			</div>
			<h1 class="reveal text-gradient mt-4 text-5xl font-semibold sm:text-6xl">What's new.</h1>
			<p class="reveal mt-5 text-lg leading-relaxed text-muted">Every release, in plain language.</p>
			<div class="reveal mt-6 rounded-lg border border-line bg-surface/50 px-4 py-3 text-sm text-faint">
				These entries are illustrative samples — replace them with real release
				notes, or we can auto-generate them from your GitHub Releases.
			</div>
		</div>
	</section>

	<section class="pb-28">
		<div class="mx-auto max-w-3xl px-5">
			<div class="relative border-l border-line pl-7 sm:pl-9">
				{
					items.map(({ entry, Content }) => (
						<article id={entry.id} class="reveal relative scroll-mt-28 pb-14">
							<span class="absolute -left-[7px] top-1.5 h-3.5 w-3.5 rounded-full border-2 border-bg bg-accent sm:-left-[9px]" />
							<div class="flex flex-wrap items-center gap-2.5">
								<time class="font-mono text-xs text-faint">{fmt(entry.data.date)}</time>
								{entry.data.version && (
									<span class="rounded border border-line-strong px-1.5 py-0.5 font-mono text-[11px] text-accent-bright">
										{entry.data.version}
									</span>
								)}
								{entry.data.tags.map((t) => (
									<span class="rounded-full bg-surface px-2 py-0.5 text-[11px] text-muted">{t}</span>
								))}
							</div>
							<h2 class="mt-3 text-2xl font-semibold tracking-tight text-cream">
								{entry.data.title}
							</h2>
							<div class="cl-body mt-3 text-[15px] leading-relaxed text-muted">
								<Content />
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>
</Page>

<style is:global>
	.cl-body p { margin: 0.5rem 0; }
	.cl-body ul { margin: 0.6rem 0; padding-left: 1.15rem; list-style: disc; }
	.cl-body li { margin: 0.3rem 0; }
	.cl-body a {
		color: var(--color-accent-bright);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}
	.cl-body strong { color: var(--color-cream); font-weight: 600; }
	.cl-body code {
		background: color-mix(in srgb, var(--color-accent) 12%, transparent);
		border: 1px solid var(--color-line);
		border-radius: 0.3rem;
		padding: 0.05rem 0.32rem;
		font-size: 0.85em;
		font-family: var(--font-mono);
	}
</style>
